# ============================================
# ExamAI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Clerk Authentication ---
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Clerk Route URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Neon PostgreSQL Database ---
# Get from: https://console.neon.tech → Connection Details
DATABASE_URL=

# --- Google Gemini AI ---
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Razorpay Payments ---
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# --- App Config (optional) ---
# Set this only if you have a custom domain. On Vercel, it auto-detects.
# NEXT_PUBLIC_APP_URL=https://your-domain.com
